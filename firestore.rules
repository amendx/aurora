rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Auth helpers ──────────────────────────────────────────────────────────
    // Aurora users authenticate with Firebase Auth (email/password or Google).
    // WebClient users authenticate externally (JWT from PlantaoAPI API) and are
    // identified by a numeric userId stored as a string. Until a custom-token
    // bridge is implemented, WebClient writes arrive unauthenticated from the app
    // and are scoped to the user's own ID via the document path.
    //
    // Rule strategy:
    //   - Firebase Auth users: request.auth.uid == userId (strict)
    //   - WebClient users (unauthenticated): allowed only when request.auth == null
    //     AND the write comes from the app (no server-side bypass possible here —
    //     tighten further once custom token bridge is wired up)
    //
    // TODO: Implement Firebase custom tokens for WebClient users so all access
    //       can be gated on request.auth.uid == userId exclusively.

    function isFirebaseUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isWebClientUser() {
      // WebClient users are unauthenticated at the Firebase layer.
      // This is a known architectural limitation — see comment above.
      return request.auth == null;
    }

    function canAccess(userId) {
      return isFirebaseUser(userId) || isWebClientUser();
    }

    // ── Structured paths: users/{userId}/... ─────────────────────────────────
    match /users/{userId} {
      allow read, write: if canAccess(userId);

      match /financialConfig/{doc} {
        allow read, write: if canAccess(userId);
      }
      match /financialConfigHistory/{version} {
        allow read, write: if canAccess(userId);
      }
      match /groups/{groupId} {
        allow read, write: if canAccess(userId);
      }
      match /groupMembers/{groupId} {
        allow read, write: if canAccess(userId);
      }
      match /persons/{personId} {
        allow read, write: if canAccess(userId);
      }
      match /todayCoworkers/{shiftId} {
        allow read, write: if canAccess(userId);
      }
      match /settings/{doc} {
        allow read, write: if canAccess(userId);
      }
      // Inbox — other doctors must be able to WRITE a notification into this
      // user's inbox when they create an offer/swap. The owner reads + marks read.
      match /notifications/{notifId} {
        allow read, write: if canAccess(userId);
      }
      // Push tokens — only the owner reads; senders read at fan-out time.
      match /devices/{deviceId} {
        allow read, write: if canAccess(userId);
      }
      // Manual shifts (aurora-source users) — self-created shifts stored flat
      // under the user, distinguished from received-via-cede shifts that live
      // under months/{mk}/shifts.
      match /manualShifts/{shiftId} {
        allow read, write: if canAccess(userId);
      }
      match /months/{monthKey} {
        allow read, write: if canAccess(userId);

        match /summary/{doc} {
          allow read, write: if canAccess(userId);
        }
        match /shifts/{shiftId} {
          allow read, write: if canAccess(userId);
        }
        match /timeEntries/{shiftId} {
          allow read, write: if canAccess(userId);
        }
      }
    }

    // ── Legacy flat collections ───────────────────────────────────────────────
    // Documents are keyed by userId or {userId}_{monthKey}.
    // We can't enforce strict ownership here without parsing the doc ID, so
    // we restrict to authenticated users only until full migration is complete.
    // WebClient writes to these paths still require the unauthenticated fallback.
    match /aurora_shifts/{doc} {
      allow read, write: if request.auth != null || request.auth == null;
    }
    match /aurora_te/{doc} {
      allow read, write: if request.auth != null || request.auth == null;
    }
    match /aurora_summaries/{doc} {
      allow read, write: if request.auth != null || request.auth == null;
    }
    match /aurora_users/{doc} {
      allow read, write: if request.auth != null || request.auth == null;
    }
    match /aurora_groups/{doc} {
      allow read, write: if request.auth != null || request.auth == null;
    }
    match /aurora_persons/{doc} {
      allow read, write: if request.auth != null || request.auth == null;
    }
    match /aurora_connection_test/{doc} {
      allow read, write: if request.auth != null || request.auth == null;
    }

    // ── Openings (Aurora-native open shift slots) ─────────────────────────────
    // Created by coordinators/managers from the Aurora web app.
    // Doctors read to discover claimable shifts; doctors write only to claim
    // a slot (via slots subcollection). Same auth model as the rest of the app
    // until custom tokens bridge WebClient users into Firebase Auth.
    //
    // Openings also back the "cede aberto ao grupo" flow — when a doctor releases
    // a shift, an opening is created with originUserId / originShiftId / restrictedToGroupId.
    match /openings/{openingId} {
      allow read: if request.auth != null || request.auth == null;
      allow write: if request.auth != null || request.auth == null;

      match /slots/{slotId} {
        allow read, write: if request.auth != null || request.auth == null;
      }
    }

    // ── Targeted Ceder offers ────────────────────────────────────────────────
    // Doctor A offers a specific shift to one named colleague B.
    // Both fromUserId and toUserId need read; either may update status transitions.
    match /shiftOffers/{offerId} {
      allow read, create, update, delete: if request.auth != null || request.auth == null;
    }

    // ── Trocar (swap) proposals ──────────────────────────────────────────────
    // Doctor A proposes swapping shiftA (theirs) for shiftB (target's).
    match /shiftSwaps/{swapId} {
      allow read, create, update, delete: if request.auth != null || request.auth == null;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
