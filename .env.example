# ─────────────────────────────────────────────────────────────────────────────
# Aurora — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in your values below
#   3. Restart the Expo dev server: npx expo start --clear
#
# SECURITY RULES:
#   • .env.local is git-ignored — never commit it
#   • This file (.env.example) MUST contain only placeholder values
#   • Never put real secrets here
#
# EXPO PUBLIC vs PRIVATE:
#   • EXPO_PUBLIC_* variables are bundled into the client app (visible to users)
#     Use only for non-secret config that's safe to expose (URLs, project IDs)
#   • Variables WITHOUT the EXPO_PUBLIC_ prefix are server-side only
#     They are NOT available in the React Native bundle
#
# EAS / CI SETUP:
#   For production builds set these via EAS Secrets:
#     eas secret:create --scope project --name EXPO_PUBLIC_FIREBASE_API_KEY --value "..."
#   Or via your CI/CD environment variables panel.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── External API ──────────────────────────────────────────────────────────────
# Base URL for the shift scheduling platform API
EXPO_PUBLIC_API_URL=https://api.your-app.com
# HTTP headers sent with every WebClient API request (impersonates the web client)
EXPO_PUBLIC_API_ORIGIN=https://web.your-app.com
EXPO_PUBLIC_API_REFERER=https://web.your-app.com/
EXPO_PUBLIC_API_USER_AGENT=Aurora-Mobile-App/1.0.0

# ── Firebase ──────────────────────────────────────────────────────────────────
# Found in: Firebase Console → Project Settings → Your Apps → SDK setup
# Note: Firebase API keys are safe to include in client bundles when Firestore
# security rules are properly configured. They identify the project, not a user.
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
EXPO_PUBLIC_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id_here
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Found in: Firebase Console → Authentication → Sign-in methods → Google
# Web client ID is safe to expose publicly (it's a public OAuth identifier)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
# iOS client ID — only needed for production builds, not Expo Go
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com

# ── Development / Demo ────────────────────────────────────────────────────────
# Optional: demo account email for local development (leave blank to disable)
EXPO_PUBLIC_DEMO_EMAIL=
# Optional: mock token used when demo email logs in (leave blank to disable)
EXPO_PUBLIC_DEMO_TOKEN=
