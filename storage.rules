rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}

/* ── REGRAS ORIGINAIS (restaurar depois) ─────────────────────────────────────

rules_version = '2';

// AURORA-ONLY: todo acesso ao Storage exige Firebase Auth. Sem fallback anônimo.

service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos: dono escreve; qualquer usuário LOGADO lê (avatar na UI).
    match /users/{userId}/profile/{file} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Demais caminhos: exigem Firebase Auth.
    match /{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}

────────────────────────────────────────────────────── FIM REGRAS ORIGINAIS */
